{
  "name": "tangleml/tangle-ui",
  "homepage": "https://tangleml.com",
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.0",
  "description": "Tangle-UI is a web app that allows the users to build and run Machine Learning pipelines using drag and drop without having to set up development environment.",
  "keywords": [
    "ML",
    "AI",
    "Machine Learning",
    "pipelines",
    "containers",
    "cloud",
    "Kubernetes",
    "MLOps"
  ],
  "bugs": "https://github.com/tangleml/tangle-ui/issues",
  "license": "Apache-2.0",
  "author": {
    "name": "Alexey Volkov",
    "email": "alexey.volkov+oss@ark-kun.com",
    "url": "http://ark-kun.com/"
  },
  "repository": "github:tangleml/tangle-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite --port 3000",
    "build": "vite build && tsc",
    "build:ghpages": "VITE_BASE_URL=/tangle-ui/ VITE_GITHUB_PAGES=true vite build --config vite.config.ghpages.js && tsc",
    "build:hf": "VITE_REQUIRE_AUTHORIZATION=true VITE_HUGGING_FACE_AUTHORIZATION=true VITE_BASE_URL=/ VITE_GITHUB_PAGES=true vite build && tsc",
    "serve": "vite preview",
    "serve:ghpages": "vite preview --config vite.config.ghpages.js",
    "test": "vitest run",
    "test:coverage": "pnpm vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ci": "playwright test --config=playwright.config.ci.ts",
    "lint": "eslint src --config eslint.config.js",
    "lint:e2e": "eslint tests/e2e --config eslint.config.js",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "gh-pages": "pnpm run build:ghpages && gh-pages -d dist",
    "lint:fix": "eslint src --config eslint.config.js --fix",
    "validate": "pnpm run format && pnpm run lint:fix && pnpm run typecheck && pnpm run knip",
    "validate:test": "pnpm run validate && pnpm run test",
    "generate-api": "openapi-ts",
    "knip": "knip",
    "fta": "fta",
    "depcruise": "depcruise",
    "hydrate-component-library": "tsx scripts/hydrate-component-library.ts public/component_library.original.yaml public/component_library.yaml"
  },
  "dependencies": {
    "@bugsnag/js": "^8.9.0",
    "@bugsnag/plugin-react": "^8.9.0",
    "@dagrejs/dagre": "^3.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@hey-api/client-fetch": "^0.13.1",
    "@hyperjump/browser": "^1.4.0",
    "@hyperjump/json-schema": "^1.17.6",
    "@monaco-editor/react": "^4.7.0",
    "@openai/agents": "^0.12.0",
    "@openai/agents-core": "^0.12.0",
    "@radix-ui/react-alert-dialog": "^1.1.18",
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-collapsible": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-radio-group": "^1.4.2",
    "@radix-ui/react-scroll-area": "^1.2.13",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slider": "^1.4.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tabs": "^1.1.16",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/history": "1.162.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/router-devtools": "1.167.0",
    "@types/gapi": "^0.0.47",
    "@types/papaparse": "^5.5.2",
    "@xyflow/react": "^12.11.1",
    "@xyflow/system": "^0.0.78",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "comlink": "^4.4.2",
    "date-fns": "^4.4.0",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "fast-deep-equal": "^3.1.3",
    "gh-pages": "^6.3.0",
    "hyparquet": "^1.26.1",
    "js-yaml": "^4.2.0",
    "localforage": "^1.10.0",
    "lucide-react": "^1.22.0",
    "mobx": "^6.16.1",
    "mobx-keystone": "^1.21.0",
    "mobx-react-lite": "^4.1.1",
    "nanoid": "^5.1.16",
    "openai": "^6.45.0",
    "papaparse": "^5.5.4",
    "prism-react-renderer": "^2.4.1",
    "pyodide": "^314.0.0",
    "random-words": "^2.0.1",
    "react": "^19.2.7",
    "react-colorful": "^5.7.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-icons": "^5.7.0",
    "react-markdown": "^10.1.0",
    "react-scan": "^0.5.7",
    "react-toastify": "^11.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "monaco-editor": "^0.54.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.7",
    "@eslint/js": "^9.39.2",
    "@hey-api/openapi-ts": "^0.99.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "dependency-cruiser": "^18.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "fake-indexeddb": "^6.2.5",
    "fta-cli": "^3.0.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "prettier": "^3.9.4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.2",
    "vite-plugin-bugsnag": "^2.0.2",
    "vitest": "^3.2.6"
  }
}
